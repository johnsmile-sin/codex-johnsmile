# ================================================================
# local-stock-assistant  환경변수 예시
#
# 사용법:
#   Windows PowerShell : Copy-Item .env.example .env
#   Mac / Linux        : cp .env.example .env
#
# 이 파일(.env.example)은 GitHub에 올려도 됩니다.
# 복사본(.env)에는 실제 값을 입력하고 절대 커밋하지 마세요.
# ================================================================


# ── 앱 동작 모드 ──────────────────────────────────────────────
# MOCK_MODE=true  → 모든 API 없이 샘플 데이터로 실행
# MOCK_MODE=false → 아래 API 키를 읽어 실제 데이터 사용
MOCK_MODE=true

# dev | prod
APP_MODE=dev


# ── Supabase (데이터베이스) ────────────────────────────────────
# 없으면 자동으로 Mock 모드로 실행됩니다.
# Supabase 대시보드 → Settings → API 에서 확인하세요.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here


# ── 키움 OpenAPI (4차: 조회 + 모의투자 전용) ──────────────────
# https://apiportal.koreainvestment.com 에서 발급 (무료)
# 없으면 FinanceDataReader(FDR)로 자동 대체됩니다.
#
# ⚠️  중요 보안 규칙:
#   - 이 파일에 실제 값을 입력하지 마세요 (.env 에 입력)
#   - 실거래 계좌번호는 절대 입력하지 않습니다
#   - KIWOOM_INVEST_MODE=mock 으로 유지하면 키 없이 동작합니다
#
KIWOOM_APP_KEY=your-kiwoom-app-key-here
KIWOOM_SECRET_KEY=your-kiwoom-secret-key-here

# 모의투자 계좌번호 (실거래 계좌 사용 금지)
# 키움증권 HTS → 계좌관리 → 모의투자 계좌번호 8자리
KIWOOM_MOCK_ACCOUNT_NO=12345678

# 투자 모드: mock(기본) | paper(모의투자 API) 중 선택
# real 은 코드 레벨에서 차단됩니다 — 입력해도 무시됩니다
KIWOOM_INVEST_MODE=mock

# 자동매매 안전 스위치 (기본값은 모두 보수적으로 설정)
# analysis_only=true  : 신호 생성만 허용, 주문 생성 불가
# require_approval=true: 주문을 대시보드 승인 후 전송
ANALYSIS_ONLY_MODE=true
REQUIRE_MANUAL_APPROVAL=true

# 1일 최대 자동 주문 건수 (0 = 무제한 — 권장하지 않음)
MAX_DAILY_AUTO_ORDERS=3

# 종목당 최대 1회 주문금액 (원) — 0이면 risk_manager 설정값 사용
MAX_ORDER_AMOUNT_PER_STOCK=500000


# ── Naver 뉴스 검색 API ───────────────────────────────────────
# 종목별 실시간 뉴스 검색에 사용합니다.
# https://developers.naver.com → 애플리케이션 등록 (무료)
# 없으면 Mock 뉴스 데이터로 대체됩니다.
NAVER_CLIENT_ID=your-naver-client-id-here
NAVER_CLIENT_SECRET=your-naver-client-secret-here


# ── OpenDART (재무 데이터) ─────────────────────────────────────
# ROE, 부채비율 등 사업보고서 기반 재무 데이터에 사용합니다.
# https://dart.fss.or.kr → 인증키 신청 (무료)
# 없으면 Mock 재무 데이터로 대체됩니다.
DART_API_KEY=your-dart-api-key-here


# ── OpenAI API (선택) ─────────────────────────────────────────
# 뉴스 요약 AI 기능에 사용합니다.
# 없으면 키워드 기반 Mock 분석으로 대체됩니다.
OPENAI_API_KEY=sk-your-openai-key-here
